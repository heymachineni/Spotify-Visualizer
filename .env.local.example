# Spotify API credentials (Client Credentials Flow)
# Create an app at https://developer.spotify.com/dashboard
# Then fill in the values below and rename this file to `.env.local`
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# OAuth redirect URI — MUST match one of the values whitelisted in the
# Spotify dashboard exactly (per environment).
#
# Local:
#   SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback
# Production (e.g. Vercel):
#   SPOTIFY_REDIRECT_URI=https://your-project.vercel.app/api/auth/callback
#
# Use the line below for local dev; set the production URL in Vercel env vars.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# (Optional) Override which prebaked landing playlists are eligible for
# random selection as the landing background. Comma/space separated. Any
# ID listed here must already exist in the prebaked snapshot — edit
# `DEFAULT_PLAYLIST_POOL` in src/lib/defaultPlaylists.ts and re-run
# `npm run prebake:landing` if you want to add new ones.
# Must be NEXT_PUBLIC_* because the module is imported into client code.
# NEXT_PUBLIC_SPOTIFY_DEFAULT_PLAYLIST_IDS=
